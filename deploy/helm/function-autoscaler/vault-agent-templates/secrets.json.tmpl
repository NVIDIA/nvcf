{{/*
  Vault Agent secrets template for the self-hosted NVCF function autoscaler.
  The OpenBao Vault Agent Injector renders this to /vault/secrets/secrets.json
  and the app reads it via SECRETS_PATH.

  Non-Cassandra credential blocks intentionally render empty unless the
  corresponding app integration is enabled and wired to a secret path.
*/}}
{
  {{- with secret `services/nvcf-api/jwt/sign/nvcf-autoscaler-service` }}
  "nvcfApiToken": "{{ .Data.token }}",
  {{- end }}
  "kv": {
    "cassandra": {
      {{- with secret "services/nvcf-autoscaler-service/kv/data/cassandra/creds" }}
      "username": "{{ .Data.data.username }}",
      "password": "{{ .Data.data.password }}"
      {{- end }}
    },
    "cassandra_ssl": {
      "tls_cert": "",
      "app_cert": "",
      "app_key": ""
    },
    "timeseries_db": {
      "username": "",
      "password": ""
    },
    "tracing": {
      "access_key": ""
    },
    "nvcf_api": {
      "client_id": "",
      "client_secret": ""
    }
  }
}
