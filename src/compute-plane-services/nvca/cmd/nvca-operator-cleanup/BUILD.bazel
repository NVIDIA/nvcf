load("@rules_go//go:def.bzl", "go_binary", "go_library", "go_test")

MODULE_PATH = "github.com/NVIDIA/nvcf/src/compute-plane-services/nvca"

go_library(
    name = "nvca-operator-cleanup_lib",
    srcs = ["main.go"],
    importpath = "github.com/NVIDIA/nvcf/src/compute-plane-services/nvca/cmd/nvca-operator-cleanup",
    visibility = ["//visibility:private"],
    deps = [
        "//pkg/client/clientset/versioned",
        "//pkg/operator/cleanup",
        "//vendor/github.com/NVIDIA/nvcf/src/libraries/go/lib/pkg/core",
        "//vendor/github.com/NVIDIA/nvcf/src/libraries/go/lib/pkg/version",
        "//vendor/github.com/urfave/cli/v2:cli",
        "//vendor/k8s.io/client-go/dynamic",
        "//vendor/k8s.io/client-go/kubernetes",
        "//vendor/k8s.io/client-go/rest",
        "//vendor/k8s.io/client-go/tools/clientcmd",
    ],
)

go_binary(
    name = "nvca-operator-cleanup",
    embed = [":nvca-operator-cleanup_lib"],
    visibility = ["//visibility:public"],
    # Mirrors ldflags.
    x_defs = {
        MODULE_PATH + "/vendor/github.com/NVIDIA/nvcf/src/libraries/go/lib/pkg/version.Version": "{STABLE_VERSION}",
        MODULE_PATH + "/vendor/github.com/NVIDIA/nvcf/src/libraries/go/lib/pkg/version.GitHash": "{STABLE_GIT_COMMIT}",
        MODULE_PATH + "/vendor/github.com/NVIDIA/nvcf/src/libraries/go/lib/pkg/version.ReleaseTag": "{STABLE_OCI_TAG}",
    },
)

go_test(
    name = "nvca-operator-cleanup_test",
    srcs = ["main_test.go"],
    embed = [":nvca-operator-cleanup_lib"],
    deps = [
        "//pkg/client/clientset/versioned",
        "//pkg/client/clientset/versioned/fake",
        "//pkg/operator/cleanup",
        "//vendor/github.com/stretchr/testify/assert",
        "//vendor/github.com/stretchr/testify/require",
        "//vendor/github.com/urfave/cli/v2:cli",
        "//vendor/k8s.io/apimachinery/pkg/runtime",
        "//vendor/k8s.io/client-go/dynamic",
        "//vendor/k8s.io/client-go/dynamic/fake",
        "//vendor/k8s.io/client-go/kubernetes",
        "//vendor/k8s.io/client-go/kubernetes/fake",
        "//vendor/k8s.io/client-go/rest",
    ],
)
