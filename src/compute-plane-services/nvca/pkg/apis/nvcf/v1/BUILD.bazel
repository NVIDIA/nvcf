        "doc.go",
        "generated.openapi.go",
        "nvcfbackend_types.go",
        "register.go",
        "zz_generated.deepcopy.go",
    ],
    importpath = "github.com/NVIDIA/nvcf/src/compute-plane-services/nvca/pkg/apis/nvcf/v1",
    visibility = ["//visibility:public"],
    deps = [
        "//pkg/featureflag",
        "//vendor/k8s.io/api/core/v1:core",
