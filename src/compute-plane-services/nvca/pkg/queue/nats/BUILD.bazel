load("@rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "nats",
    srcs = [
        "client.go",
        "client_psat.go",
        "host.go",
        "nats.go",
    ],
    importpath = "github.com/NVIDIA/nvcf/src/compute-plane-services/nvca/pkg/queue/nats",
    visibility = ["//visibility:public"],
    deps = [
        "//internal/auth",
        "//pkg/queue",
        "//vendor/github.com/NVIDIA/nvcf/src/libraries/go/lib/pkg/core",
        "//vendor/github.com/nats-io/nats.go:nats_go",
        "//vendor/github.com/nats-io/nats.go/jetstream",
        "//vendor/github.com/nats-io/nkeys",
        "//vendor/github.com/sirupsen/logrus",
    ],
)

alias(
    name = "go_default_library",
    actual = ":nats",
    visibility = ["//visibility:public"],
)

go_test(
    name = "nats_test",
    srcs = [
        "client_psat_test.go",
        "client_test.go",
        "host_test.go",
    ],
    embed = [":nats"],
    deps = [
        "//internal/auth",
        "//pkg/queue",
        "//vendor/github.com/nats-io/nats.go:nats_go",
        "//vendor/github.com/nats-io/nats-server/v2/server",
        "//vendor/github.com/nats-io/nats-server/v2/test",
        "//vendor/github.com/nats-io/nkeys",
        "//vendor/github.com/stretchr/testify/assert",
        "//vendor/github.com/stretchr/testify/require",
    ],
)
