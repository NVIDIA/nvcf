load("@rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "file",
    srcs = ["file.go"],
    importpath = "github.com/hashicorp/vault/sdk/physical/file",
    visibility = ["//visibility:public"],
    deps = [
        "//sdk/helper/consts",
        "//sdk/helper/jsonutil",
        "//sdk/physical",
        "@com_github_hashicorp_errwrap//:errwrap",
        "@com_github_hashicorp_go_hclog//:go-hclog",
    ],
)

alias(
    name = "go_default_library",
    actual = ":file",
    visibility = ["//visibility:public"],
)

go_test(
    name = "file_test",
    srcs = ["file_test.go"],
    embed = [":file"],
    deps = [
        "//sdk/helper/logging",
        "//sdk/physical",
        "@com_github_hashicorp_go_hclog//:go-hclog",
    ],
)
