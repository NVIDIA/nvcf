load("@rules_go//go:def.bzl", "go_library")

go_library(
    name = "dbplugin",
    srcs = [
        "client.go",
        "database.pb.go",
        "database_grpc.pb.go",
        "databasemiddleware.go",
        "grpc_transport.go",
        "plugin.go",
        "server.go",
    ],
    importpath = "github.com/hashicorp/vault/sdk/database/dbplugin",
    visibility = ["//visibility:public"],
    deps = [
        "//sdk/helper/consts",
        "//sdk/helper/pluginutil",
        "@com_github_armon_go_metrics//:go-metrics",
        "@com_github_golang_protobuf//ptypes",
        "@com_github_hashicorp_errwrap//:errwrap",
        "@com_github_hashicorp_go_hclog//:go-hclog",
        "@com_github_hashicorp_go_plugin//:go-plugin",
        "@org_golang_google_grpc//:grpc",
        "@org_golang_google_grpc//codes",
        "@org_golang_google_grpc//status",
        "@org_golang_google_protobuf//reflect/protoreflect",
        "@org_golang_google_protobuf//runtime/protoimpl",
        "@org_golang_google_protobuf//types/known/timestamppb",
    ],
)

alias(
    name = "go_default_library",
    actual = ":dbplugin",
    visibility = ["//visibility:public"],
)
