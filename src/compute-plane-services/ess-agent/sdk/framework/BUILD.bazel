    data = glob(["testdata/**"]),
    embed = [":framework"],
    deps = [
        "//sdk/helper/consts",
        "//sdk/helper/jsonutil",
        "//sdk/helper/salt",
        "//sdk/helper/wrapping",
        "//sdk/logical",
        "@com_github_go_test_deep//:deep",
        "@com_github_hashicorp_go_secure_stdlib_strutil//:strutil",
