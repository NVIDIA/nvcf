load("@rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "custommetadata",
    srcs = ["custom_metadata.go"],
    importpath = "github.com/hashicorp/vault/sdk/helper/custommetadata",
    visibility = ["//visibility:public"],
    deps = [
        "@com_github_hashicorp_go_multierror//:go-multierror",
        "@com_github_hashicorp_go_secure_stdlib_strutil//:strutil",
        "@com_github_mitchellh_mapstructure//:mapstructure",
    ],
)

alias(
    name = "go_default_library",
    actual = ":custommetadata",
    visibility = ["//visibility:public"],
)

go_test(
    name = "custommetadata_test",
    srcs = ["custom_metadata_test.go"],
    embed = [":custommetadata"],
)
