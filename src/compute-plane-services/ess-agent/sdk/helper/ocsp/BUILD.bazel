load("@rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "ocsp",
    srcs = ["client.go"],
    importpath = "github.com/hashicorp/vault/sdk/helper/ocsp",
    visibility = ["//visibility:public"],
    deps = [
        "//sdk/helper/certutil",
        "@com_github_hashicorp_go_hclog//:go-hclog",
        "@com_github_hashicorp_go_retryablehttp//:go-retryablehttp",
        "@com_github_hashicorp_golang_lru//:golang-lru",
        "@org_golang_x_crypto//ocsp",
    ],
)

alias(
    name = "go_default_library",
    actual = ":ocsp",
    visibility = ["//visibility:public"],
)

go_test(
    name = "ocsp_test",
    srcs = ["ocsp_test.go"],
    embed = [":ocsp"],
    deps = [
        "@com_github_hashicorp_go_hclog//:go-hclog",
        "@com_github_hashicorp_go_retryablehttp//:go-retryablehttp",
        "@com_github_hashicorp_golang_lru//:golang-lru",
        "@org_golang_x_crypto//ocsp",
    ],
)
