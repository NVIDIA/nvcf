load("@rules_go//go:def.bzl", "go_library")

go_library(
    name = "tokenutil",
    srcs = ["tokenutil.go"],
    importpath = "github.com/hashicorp/vault/sdk/helper/tokenutil",
    visibility = ["//visibility:public"],
    deps = [
        "//sdk/framework",
        "//sdk/helper/policyutil",
        "//sdk/logical",
        "@com_github_hashicorp_go_secure_stdlib_parseutil//:parseutil",
        "@com_github_hashicorp_go_secure_stdlib_strutil//:strutil",
        "@com_github_hashicorp_go_sockaddr//:go-sockaddr",
