load("@rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "policyutil",
    srcs = ["policyutil.go"],
    importpath = "github.com/hashicorp/vault/sdk/helper/policyutil",
    visibility = ["//visibility:public"],
    deps = ["@com_github_hashicorp_go_secure_stdlib_strutil//:strutil"],
)

alias(
    name = "go_default_library",
    actual = ":policyutil",
    visibility = ["//visibility:public"],
)

go_test(
    name = "policyutil_test",
    srcs = ["policyutil_test.go"],
    embed = [":policyutil"],
)
