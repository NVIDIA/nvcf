load("@rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "ldaputil",
    srcs = [
        "client.go",
        "config.go",
        "connection.go",
        "ldap.go",
    ],
    importpath = "github.com/hashicorp/consul-template/sdk/helper/ldaputil",
    visibility = ["//visibility:public"],
    deps = [
        "@com_github_go_ldap_ldap_v3//:ldap",
        "@com_github_hashicorp_errwrap//:errwrap",
        "@com_github_hashicorp_go_hclog//:go-hclog",
        "@com_github_hashicorp_go_multierror//:go-multierror",
        "@com_github_hashicorp_go_secure_stdlib_tlsutil//:tlsutil",
        "@com_github_hashicorp_vault_sdk//framework",
    ],
)

alias(
    name = "go_default_library",
    actual = ":ldaputil",
    visibility = ["//visibility:public"],
)

go_test(
    name = "ldaputil_test",
    srcs = [
        "client_test.go",
        "config_test.go",
    ],
    embed = [":ldaputil"],
    deps = [
        "@com_github_go_test_deep//:deep",
        "@com_github_hashicorp_go_hclog//:go-hclog",
        "@com_github_hashicorp_vault_sdk//framework",
    ],
)
