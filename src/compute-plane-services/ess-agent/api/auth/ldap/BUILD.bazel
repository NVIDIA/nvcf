load("@rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "ldap",
    srcs = ["ldap.go"],
    importpath = "github.com/hashicorp/consul-template/api/auth/ldap",
    visibility = ["//visibility:public"],
    deps = ["@com_github_hashicorp_vault_api//:api"],
)

alias(
    name = "go_default_library",
    actual = ":ldap",
    visibility = ["//visibility:public"],
)

go_test(
    name = "ldap_test",
    srcs = ["ldap_test.go"],
    embed = [":ldap"],
    deps = ["@com_github_hashicorp_vault_api//:api"],
)
