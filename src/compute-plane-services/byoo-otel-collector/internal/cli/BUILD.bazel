load("@rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "cli",
    srcs = ["cli.go"],
    importpath = "github.com/NVIDIA/nvcf/src/compute-plane-services/byoo-otel-collector/internal/cli",
    visibility = ["//:__subpackages__"],
    deps = [
        "//internal/logger",
        "//internal/metrics",
        "//internal/otelcollector",
        "//internal/otelconfig",
        "//internal/secrets",
        "@com_github_spf13_cobra//:cobra",
        "@com_github_spf13_pflag//:pflag",
    ],
)

alias(
    name = "go_default_library",
    actual = ":cli",
    visibility = ["//:__subpackages__"],
)

go_test(
    name = "cli_test",
    srcs = ["cli_test.go"],
    embed = [":cli"],
    deps = [
        "//internal/logger",
        "@org_uber_go_zap//:zap",
        "@org_uber_go_zap//zapcore",
        "@org_uber_go_zap//zaptest/observer",
    ],
)
