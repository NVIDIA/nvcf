load("@rules_go//go:def.bzl", "go_library", "go_test")

genrule(
    name = "skilldata_generated_go",
    srcs = ["//ai-tooling/user/skills:nvcf_public_user_skills"],
    outs = ["skilldata_generated.go"],
    cmd = "$(location //src/clis/nvcf-cli/internal/agentskill/skilldatagen) -strip-prefix=ai-tooling/user/skills -out=$@ $(SRCS)",
    tools = ["//src/clis/nvcf-cli/internal/agentskill/skilldatagen"],
)

go_library(
    name = "agentskill",
    srcs = [
        "install.go",
        "manifest.go",
        ":skilldata_generated_go",
    ],
    importpath = "nvcf-cli/internal/agentskill",
    visibility = ["//src/clis/nvcf-cli:__subpackages__"],
)

go_test(
    name = "agentskill_test",
    srcs = [
        "install_test.go",
        "manifest_test.go",
    ],
    embed = [":agentskill"],
)
